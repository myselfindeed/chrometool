{
  "manifest_version": 3,
  "name": "Web元素数据采集器",
  "version": "1.0.0",
  "description": "帮助用户快速从网页中提取指定元素内容，并导出为结构化Excel文件",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Web元素数据采集器",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["scripts/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },
  "commands": {
    "toggle_sidepanel": {
      "suggested_key": {
        "default": "Alt+W",
        "mac": "Alt+W"
      },
      "description": "打开/关闭侧边栏"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
